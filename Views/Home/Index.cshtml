@{
    ViewBag.Title = "Inicio";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">GestionTickets</h1>
        <p class="lead text-muted">Compra y gestiona tickets para eventos en toda Centroamérica</p>
        <a href="/Eventos" class="btn btn-primary me-2">Ver Eventos</a>
        @Html.ActionLink("Crear Cuenta", "Registrar", "Acceso", null, new { @class = "btn btn-outline-secondary" })
    </div>

    <hr />

    <h4 class="mb-4">Módulos del sistema</h4>
    <div class="row g-3">

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Eventos</h5>
                    <p class="card-text text-muted">Explora y gestiona eventos por categoría y venue.</p>
                    <a href="/Eventos" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Artistas</h5>
                    <p class="card-text text-muted">Catálogo de artistas y sus presentaciones.</p>
                    <a href="/Artistas" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Venues</h5>
                    <p class="card-text text-muted">Estadios, teatros y auditorios disponibles.</p>
                    <a href="/Venues" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Tickets</h5>
                    <p class="card-text text-muted">Compra y administra tus entradas.</p>
                    <a href="/Compras" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Mi Agenda</h5>
                    <p class="card-text text-muted">Guarda las presentaciones que no te quieres perder.</p>
                    <a href="/Agenda" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Notificaciones</h5>
                    <p class="card-text text-muted">Recordatorios y confirmaciones de compra.</p>
                    <a href="/Notificaciones" class="btn btn-sm btn-outline-primary">Ver</a>
                </div>
            </div>
        </div>

    </div>
</div>