@model IEnumerable<GestionTickets.sp_mostrar_presentaciones_Result>
@{ ViewBag.Title = "Presentaciones"; }

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2> Presentaciones</h2>
        <a href="@Url.Action("Crear")" class="btn btn-primary"> Nueva Presentación</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Evento</th>
                <th>Artista</th>
                <th>Escenario</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Orden</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.evento</td>
                    <td>@p.artista</td>
                    <td>@p.escenario</td>
                    <td>@p.fecha_hora_inicio.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(p.fecha_hora_fin.HasValue ? p.fecha_hora_fin.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                    <td>@p.orden</td>
                    <td>
                        @if (p.activo == true)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </td>
                    <td>
                        <a href="@Url.Action("Editar", new { id = p.id_presentacion })" class="btn btn-sm btn-warning">Editar</a>
                        @using (Html.BeginForm("Eliminar", "Presentaciones", new { id = p.id_presentacion }, FormMethod.Post))
                        {
                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                        }
                        @if (p.activo == false)
                        {
                            using (Html.BeginForm("Activar", "Presentaciones", new { id = p.id_presentacion }, FormMethod.Post))
                            {
                                <button type="submit" class="btn btn-sm btn-success">Activar</button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>