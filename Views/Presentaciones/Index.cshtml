@model IEnumerable<GestionTickets.sp_mostrar_presentaciones_Result>
@{ ViewBag.Title = "Presentaciones"; }
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Presentaciones</h2>
        <a href="@Url.Action("Crear")" class="btn btn-primary">Nueva Presentacion</a>
    </div>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Evento</th>
                <th>Artista</th>
                <th>Escenario</th>
                <th>Inicio</th>
                <th>Fin</th>
                <th>Orden</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.evento</td>
                    <td>@p.artista</td>
                    <td>@p.escenario</td>
                    <td>@p.fecha_hora_inicio.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(p.fecha_hora_fin.HasValue ? p.fecha_hora_fin.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                    <td>@p.orden</td>
                    <td>
                        @if (p.activo == true)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </td>
                    <td>
                        @* Boton de like *@
                        @{
                            var likes = ViewBag.Likes as List<int?>;
                            bool tieneLike = likes != null && likes.Contains(p.id_presentacion);
                        }
                        @using (Html.BeginForm("Toggle", "Likes", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id_usuario" value="@ViewBag.id_usuario" />
                            <input type="hidden" name="id_presentacion" value="@p.id_presentacion" />
                            <input type="hidden" name="returnUrl" value="@Request.Url.PathAndQuery" />
                            <button type="submit" class="btn btn-sm btn-light" title="@(tieneLike ? "Quitar de agenda" : "Agregar a agenda")">
                                @if (tieneLike)
                                {
                                    // Corazon lleno
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                        <path fill="#e14a4a" d="M12 20.25c-.37 0-.74-.14-1.02-.42l-7.96-7.96A5.2 5.2 0 0 1 1.5 8.25a5.75 5.75 0 0 1 9.9-3.96A5.75 5.75 0 0 1 22.5 8.25c0 1.45-.59 2.75-1.54 3.71l-7.94 7.87c-.28.28-.65.42-1.02.42z" />
                                    </svg>
                                }
                                else
                                {
                                    // Corazon vacio
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                        <path fill="#e14a4a" d="M4.24 12.25a4.2 4.2 0 0 1-1.24-3A4.25 4.25 0 0 1 7.25 5c1.58 0 2.96.86 3.69 2.14h1.12A4.24 4.24 0 0 1 15.75 5A4.25 4.25 0 0 1 20 9.25c0 1.17-.5 2.25-1.24 3L11.5 19.5zm15.22.71C20.41 12 21 10.7 21 9.25A5.25 5.25 0 0 0 15.75 4c-1.75 0-3.3.85-4.25 2.17A5.22 5.22 0 0 0 7.25 4A5.25 5.25 0 0 0 2 9.25c0 1.45.59 2.75 1.54 3.71l7.96 7.96z" />
                                    </svg>
                                }
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>