@model GestionTickets.venues

@{
    ViewBag.Title = "Eliminar Venue";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow bg-white">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Eliminar Venue</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        ¿Seguro que deseas eliminar este venue?
                        <br />
                       
                    </div>
                    <dl class="row mb-4">
                        <dt class="col-sm-4">Nombre</dt>
                        <dd class="col-sm-8">@Model.nombre</dd>

                        <dt class="col-sm-4">Tipo</dt>
                        <dd class="col-sm-8">@Model.tipo</dd>

                        <dt class="col-sm-4">Dirección</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.direccion) ? "-" : Model.direccion)</dd>

                        <dt class="col-sm-4">Ciudad</dt>
                        <dd class="col-sm-8">
                            @(Model.ciudades != null ? Model.ciudades.nombre : "Sin ciudad")
                        </dd>

                        <dt class="col-sm-4">Capacidad</dt>
                        <dd class="col-sm-8">
                            @(Model.capacidad.HasValue ? Model.capacidad.Value.ToString() : "-")
                        </dd>

                        <dt class="col-sm-4">URL imagen</dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrEmpty(Model.imagen_url) ? "-" : Model.imagen_url)
                        </dd>

                        <dt class="col-sm-4">Activo</dt>
                        <dd class="col-sm-8">
                            @(Model.activo == true ? "Sí" : "No")
                        </dd>
                    </dl>

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <div class="d-flex justify-content-between">
                            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-secondary" })
                            <input type="submit" value="Eliminar" class="btn btn-danger" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>