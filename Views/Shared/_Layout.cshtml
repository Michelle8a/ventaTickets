@{
    var usuario = Session["usuario"] as GestionTickets.usuarios;
    var rol = Session["rol"] as string;
}
<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - GestionTickets</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/Content/css/Auth.css" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>


    <div class="topbar" style="display:flex; justify-content:space-between; align-items:center; padding:10px 20px;">

        <div style="display:flex; align-items:center;">
            <button class="hamburger" id="menuToggle">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <a href="@Url.Action("Index", "Home")" class="app-title" style="margin-left:10px;">GestionTickets</a>
        </div>

        <div style="display:flex; align-items:center; gap:10px;">

            @if (usuario != null)
            {
                <div style="display:flex; align-items:center; background:#1e293b; padding:6px 12px; border-radius:20px; color:white;">
                    <span style="margin-right:6px;">👤</span>
                    <span style="font-weight:500;">@usuario.nombre</span>
                </div>

                <a href="#" onclick="confirmarLogout()"
                   style="background:#ef4444; color:white; padding:6px 10px; border-radius:8px; text-decoration:none;">
                    Cerrar
                </a>
            }
            else
            {
                <a href="@Url.Action("Login","Acceso")"
                   style="background:#3b82f6; color:white; padding:6px 10px; border-radius:8px; text-decoration:none;">
                    Login
                </a>
            }

        </div>
    </div>


    <div class="overlay" id="overlay"></div>

    <div class="sidebar" id="sidebar">
        <ul>
            <li class="sidebar-section">General</li>
            <li>@Html.ActionLink("Inicio", "Index", "Home")</li>

            <li class="sidebar-section">Eventos</li>

            <li>@Html.ActionLink("Eventos", "Index", "Eventos")</li>
            <li>@Html.ActionLink("Presentaciones", "Index", "Presentaciones")</li>
            <li>@Html.ActionLink("Artistas", "Index", "Artistas")</li>
            <li>@Html.ActionLink("Categorias", "Index", "Categorias")</li>

            <li class="sidebar-section">Lugares</li>

            @if (rol == "Organizador" || rol == "Admin")
            {
                <li>@Html.ActionLink("Venues", "Index", "Venues")</li>
                <li>@Html.ActionLink("Secciones", "Index", "Secciones")</li>
                <li>@Html.ActionLink("Ciudades", "Index", "Ciudades")</li>
                <li>@Html.ActionLink("Paises", "Index", "Paises")</li>
            }

            <li class="sidebar-section">Ventas</li>

            @if (usuario != null)
            {
                <li>@Html.ActionLink("Tipos de Ticket", "Index", "TiposTicket")</li>
                <li>@Html.ActionLink("Compras", "Index", "Compras")</li>
                <li>@Html.ActionLink("Pagos", "Index", "Pagos")</li>
                <li>@Html.ActionLink("Descuentos", "Index", "Descuentos")</li>
                <li>@Html.ActionLink("Reembolsos", "Index", "Reembolsos")</li>
            }

            <li class="sidebar-section">Usuarios</li>

            @if (rol == "Admin")
            {
                <li>@Html.ActionLink("Usuarios", "Index", "Usuarios")</li>
                <li>@Html.ActionLink("Roles", "Index", "Roles")</li>

                <li>@Html.ActionLink("Crear Organizador", "Crear", "Organizadores")</li>
            }
            <li class="sidebar-section">Reportes</li>

            @if (rol == "Admin")
            {
                <li>@Html.ActionLink("Reportes Administrador", "ReporteAdmin", "Dashboard")</li>
            }
            @if (rol == "Organizador")
            {
                <li>@Html.ActionLink("Reportes Organizador", "ReporteOrganizador", "Dashboard")</li>
            }

            <li class="sidebar-section">Otros</li>

            @if (usuario != null)
            {
                <li>@Html.ActionLink("Notificaciones", "Index", "Notificaciones")</li>
                <li>@Html.ActionLink("Agenda", "Index", "Agenda")</li>
                <li>@Html.ActionLink("Likes", "Index", "Likes")</li>
                <li>@Html.ActionLink("Conversiones", "Index", "Conversiones")</li>
            }

            <li class="sidebar-section">Cuenta</li>

            @if (usuario != null)
            {
                <a href="#" onclick="event.preventDefault(); confirmarLogout();"
                   style="background:#ef4444; color:white; padding:6px 10px; border-radius:8px; text-decoration:none; display:inline-block; text-align: center; width:80%; margin:10px auto; text-align:center;">
                    Cerrar Sesión
                </a>
            }
            else
            {
                <a href="@Url.Action("Login","Acceso")"
                   style="background: #3b82f6; color: white; padding: 6px 10px; border-radius: 8px; text-decoration: none; text-align: center; width:80%; margin:10px auto; text-align:center;">
                    Iniciar Sesión
                </a>
            }
        </ul>
    </div>

    <div class="main-content">
        @RenderBody()
        <footer>
            <p>&copy; @DateTime.Now.Year - GestionTickets</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    <script>
        const toggle = document.getElementById('menuToggle');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');

        toggle.addEventListener('click', function () {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
        });

        overlay.addEventListener('click', function () {
            sidebar.classList.remove('open');
            overlay.classList.remove('active');
        });
    </script>

    <script>
        function confirmarLogout() {
            Swal.fire({
                title: '¿Cerrar sesión?',
                text: "¿Seguro que quieres salir?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, cerrar sesión',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '/Acceso/Logout';
                }
            });
        }
    </script>

</body>
</html>