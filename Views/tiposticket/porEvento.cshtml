@model IEnumerable<GestionTickets.tipos_ticket>

@{
    var rol = Session["rol"] as string;
    bool habilitar = rol == "Admin";
    ViewBag.Title = "Tickets del Evento";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Tickets del Evento</h2>
            <p class="text-muted mb-0">
                @(ViewBag.EventoNombre != null ? ViewBag.EventoNombre : "Evento")
            </p>
        </div>

        <div>
            @Html.ActionLink("Volver a eventos", "Index", "Eventos", null, new { @class = "btn btn-secondary me-2" })
            @if (habilitar)
            {

                @Html.ActionLink(
                         "Crear ticket",
                         "Create",
                         "TiposTicket",
                         new { idEvento = ViewBag.IdEvento },
                         new { @class = "btn btn-success" }
                     )
            }
            </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Este evento todavía no tiene tipos de ticket registrados.
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var ticket in Model)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm bg-white">

                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@ticket.nombre</h5>
                        </div>

                        <div class="card-body">
                            <p class="mb-2">
                                <strong>Sección:</strong>
                                @(ticket.secciones_venue != null ? ticket.secciones_venue.nombre : "Sin sección")
                            </p>

                            <p class="mb-2">
                                <strong>Precio:</strong>
                                @ticket.moneda @ticket.precio.ToString("N2")
                            </p>

                            <p class="mb-2">
                                <strong>Cantidad disponible:</strong>
                                @ticket.cantidad_ticket
                            </p>

                            <p class="mb-2">
                                <strong>Venta inicio:</strong>
                                @(ticket.venta_inicio.HasValue ? ticket.venta_inicio.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </p>

                            <p class="mb-0">
                                <strong>Venta fin:</strong>
                                @(ticket.venta_fin.HasValue ? ticket.venta_fin.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                            </p>
                        </div>

                        <div class="card-footer bg-white">
                            <div class="d-grid gap-2">

                                <a href="@Url.Action("Create", "Pagos", new { idTipoTicket = ticket.id_tipo_ticket })"
                                   class="btn btn-sm btn-success">
                                    Comprar
                                </a>

                                @Html.ActionLink("Detalles", "Details", "TiposTicket", new { id = ticket.id_tipo_ticket }, new { @class = "btn btn-sm btn-info" })
                                @if (habilitar)
                                {
                                    @Html.ActionLink("Editar", "Edit", "TiposTicket", new { id = ticket.id_tipo_ticket }, new { @class = "btn btn-sm btn-warning" })
                                    @Html.ActionLink("Eliminar", "Delete", "TiposTicket", new { id = ticket.id_tipo_ticket }, new { @class = "btn btn-sm btn-danger" })
                                }
                                </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                    Swal.fire({
                        title: "Operación realizada",
                        text: "@TempData["SuccessMessage"]",
                        icon: "success",
                        confirmButtonText: "Aceptar",
                        confirmButtonColor: "#0d6efd"
                    });
                </text>
            }
        });
    </script>
}