@model GestionTickets.tipos_ticket

@{
    ViewBag.Title = "Detalle Tipo de Ticket";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <div class="card shadow bg-white">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Detalle Tipo de Ticket</h4>
                </div>

                <div class="card-body">

                    <dl class="row mb-4">
                        <dt class="col-sm-4">Evento</dt>
                        <dd class="col-sm-8">
                            @(Model.eventos != null ? Model.eventos.nombre : "Sin evento")
                        </dd>

                        <dt class="col-sm-4">Sección</dt>
                        <dd class="col-sm-8">
                            @(Model.secciones_venue != null ? Model.secciones_venue.nombre : "Sin sección")
                        </dd>

                        <dt class="col-sm-4">Ticket</dt>
                        <dd class="col-sm-8">@Model.nombre</dd>

                        <dt class="col-sm-4">Precio</dt>
                        <dd class="col-sm-8">@Model.moneda @Model.precio.ToString("N2")</dd>

                        <dt class="col-sm-4">Cantidad</dt>
                        <dd class="col-sm-8">@Model.cantidad_ticket</dd>

                        <dt class="col-sm-4">Inicio venta</dt>
                        <dd class="col-sm-8">
                            @(Model.venta_inicio.HasValue ? Model.venta_inicio.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                        </dd>

                        <dt class="col-sm-4">Fin venta</dt>
                        <dd class="col-sm-8">
                            @(Model.venta_fin.HasValue ? Model.venta_fin.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                        </dd>

                        <dt class="col-sm-4">Activo</dt>
                        <dd class="col-sm-8">
                            @(Model.activo == true ? "Sí" : "No")
                        </dd>
                    </dl>

                    <div class="d-flex justify-content-between">
                        @Html.ActionLink("Volver", "PorEvento", "TiposTicket", new { id = Model.id_evento }, new { @class = "btn btn-secondary" })
                        @Html.ActionLink("Editar", "Edit", "TiposTicket", new { id = Model.id_tipo_ticket }, new { @class = "btn btn-warning" })
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>