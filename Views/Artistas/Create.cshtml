@model GestionTickets.artistas

@{
    ViewBag.Title = "Crear Artista";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">

            <div class="card shadow bg-white">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Crear Artista</h4>
                </div>

                <div class="card-body">

                    @using (Html.BeginForm("Create", "Artistas", FormMethod.Post, new { id = "formCrearArtista" }))
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                        <div class="mb-3">
                            @Html.LabelFor(model => model.nombre, "Nombre del artista", new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.nombre, new { @class = "form-control", placeholder = "Nombre del artista o grupo" })
                            @Html.ValidationMessageFor(model => model.nombre, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.genero, "Género", new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.genero, new { @class = "form-control", placeholder = "Rock, Pop, Electrónica, Teatro..." })
                            @Html.ValidationMessageFor(model => model.genero, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.descripcion, "Descripción", new { @class = "form-label" })
                            @Html.TextAreaFor(model => model.descripcion, new { @class = "form-control", rows = 4, placeholder = "Breve descripción del artista" })
                            @Html.ValidationMessageFor(model => model.descripcion, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(model => model.imagen_url, "URL de imagen", new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.imagen_url, new { @class = "form-control", placeholder = "https://..." })
                            @Html.ValidationMessageFor(model => model.imagen_url, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-check mb-4">
                            @Html.CheckBox("activo", true, new { @class = "form-check-input" })
                            @Html.LabelFor(model => model.activo, "Activo", new { @class = "form-check-label" })
                            @Html.ValidationMessageFor(model => model.activo, "", new { @class = "text-danger d-block" })
                        </div>

                        <div class="d-flex justify-content-between">
                            @Html.ActionLink("Volver", "Index", "Artistas", null, new { @class = "btn btn-secondary" })

                            <button type="button" id="btnCrearArtista" class="btn btn-primary">
                                Guardar
                            </button>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $("#btnCrearArtista").on("click", function () {
                Swal.fire({
                    title: "¿Crear artista?",
                    text: "Se guardará el nuevo artista.",
                    icon: "question",
                    showCancelButton: true,
                    confirmButtonText: "Sí, guardar",
                    cancelButtonText: "Cancelar",
                    confirmButtonColor: "#0d6efd",
                    cancelButtonColor: "#6c757d"
                }).then((result) => {
                    if (result.isConfirmed) {
                        $("#formCrearArtista").submit();
                    }
                });
            });
        });
    </script>
}